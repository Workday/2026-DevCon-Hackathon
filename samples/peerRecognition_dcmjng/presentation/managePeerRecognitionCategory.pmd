{
  "id": "managePeerRecognitionCategory",
  "_generationNote": "This page is designed for app administrators to quickly manage PeerRecognitionCategory business object data for the app. ",
  "_generationNote2": "It is strongly advised to configure the `securityDomains` for this page to allow only the appropriate personas to access it.",
  "securityDomains": [],
  "script": "",
  "endPoints": [
    {
      "name": "getPeerRecognitionCategories",
      "httpMethod": "GET",
      "authType": "sso",
