                "valuesOut": [
                  {
                    "valueOutBinding": "createPeerRecognitionCategory.name",
                    "value": "<% self.value %>"
                  },
                  {
                    "valueOutBinding": "updatePeerRecognitionCategory.name",
                    "value": "<% self.value %>"
                  }
                ]
              }
            },
            {
              "type": "column",
              "columnId": "referenceColumn",
              "label": "Reference",
              "cellTemplate": {
                "type": "text",
                "id": "reference",
