                  },
                  {
                    "valueOutBinding": "updatePeerRecognitionCategory.id",
                    "value": "<% self.value %>"
                  }
                ]
              }
            },
            {
              "type": "column",
              "columnId": "nameColumn",
              "label": "Name",
              "cellTemplate": {
