                "valuesOut": [
                  {
                    "valueOutBinding": "createPeerRecognitionCategory.reference",
                    "value": "<% self.value %>"
                  },
                  {
                    "valueOutBinding": "updatePeerRecognitionCategory.reference",
                    "value": "<% self.value %>"
                  }
                ]
              }
