{
  "id": "singleColumnLayoutViewPage",
  "endPoints": [ ],
  "presentation": {
    "pageType": "view",
    "title": {
      "type": "title",
      "label": "Workday Extend Column Layout Single Column View Page"
    },
    "body": {
      "type": "columnLayout",
      "id": "columnLayoutId",
      "columns": [
        {
          "type": "layoutSection",
          "children": [
            {
              "type": "fieldSet",
              "id": "rightSection",
              "title": "Column 3",
              "horizontal": true,
              "columnWidthRatios": [
                0.3,
                0.3,
                0.3
              ],
              "children": [
                {
                  "type": "section",
                  "id": "rightSubSection1",
                  "horizaontal": false,
                  "children": [
                    {
                      "type": "text",
                      "id": "rightFirstName",
                      "label": "First Name"
                    },
                    {
                      "type": "text",
                      "id": "rightLastName",
                      "label": "Last Name"
                    }
                  ]
                },
                {
