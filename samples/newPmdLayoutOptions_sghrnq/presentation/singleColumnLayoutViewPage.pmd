                    },
                    {
                      "type": "text",
                      "id": "rightLastName",
                      "label": "Last Name Blah"
                    },
                    {
                      "type": "dropdown",
                      "id": "rightCurrency",
                      "label": "Currency",
                      "selectedValues": "<% ['USD'] %>",
                      "instanceList": [
                        {
                          "id": "USD",
                          "descriptor": "USD"
                        },
                        {
                          "id": "GBP",
                          "descriptor": "GBP"
                        },
                        {
